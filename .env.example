# 个人知识管理系统 (PKMS) 环境变量配置
# 复制此文件为 .env 并填写实际值

# ==================== 后端配置 ====================

# 运行环境 (development | production)
NODE_ENV=development

# 后端服务端口
PORT=4000

# SQLite 数据库路径
DATABASE_URL=./data/pkms.db

# 数据存储目录
DATA_DIR=./data

# 文件存储目录
STORAGE_DIR=./storage

# ==================== 安全配置 ====================

# JWT 签名密钥 (必填！)
# 生成方法：echo "your-random-secret-key-here"
JWT_SECRET=your-jwt-secret-key-here

# 数据加密密钥 (必填！32 字节)
# 生成方法：openssl rand -base64 32
PKMS_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ==================== 前端配置 ====================

# 前端地址 (用于 CORS)
FRONTEND_URL=http://localhost:3000

# ==================== 其他配置 ====================

# 日志级别 (debug | info | warn | error)
LOG_LEVEL=info
